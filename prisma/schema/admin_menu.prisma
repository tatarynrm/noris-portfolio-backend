// =============================================================
//  ADMIN MENU
//  Navigation links for the admin panel
// =============================================================

model admin_menu {
  menu_id    String   @id @default(uuid())
  title      String   @unique
  link       String
  icon       String?
  sequence   Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}
